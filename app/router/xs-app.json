{
  "welcomeFile": "/pizza-order/index.html",
  "authenticationMethod": "route",
  "routes": [
    { "source": "^/api/order/(.*)$",  "target": "/api/order/$1",  "destination": "srv-api", "authenticationType": "xsuaa" },
    { "source": "^/api/store/(.*)$",  "target": "/api/store/$1",  "destination": "srv-api", "authenticationType": "xsuaa" },
    { "source": "^/api/admin/(.*)$",  "target": "/api/admin/$1",  "destination": "srv-api", "authenticationType": "xsuaa" },
    { "source": "^(.*)$", "target": "$1", "service": "html5-apps-repo-rt", "authenticationType": "xsuaa" }
  ]
}
